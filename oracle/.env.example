# The Orchard — Oracle service config.
#
# Copy to oracle/.env and edit. .env is in .gitignore — your local
# values stay local. Defaults below are sensible for a local single-PC
# deployment.

# Where to listen.
ORCHARD_ORACLE_HOST=0.0.0.0
ORCHARD_ORACLE_PORT=8000

# Where SQLite stores readings + registrations.
# Defaults to oracle/data/orchard.db (created on first run).
ORCHARD_ORACLE_DB_URL=sqlite:///./oracle/data/orchard.db

# uvicorn log level: critical, error, warning, info, debug, trace
ORCHARD_ORACLE_LOG_LEVEL=info

# Day-aligned Season anchor (UTC midnight of this date == start of Season 1).
# v1 uses simple day-based Seasons; Phase 5 replaces this with real
# Chia-block-aligned Seasons via DataLayer.
ORCHARD_SEASON_GENESIS_DATE=2026-05-27
