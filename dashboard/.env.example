# The Orchard — Orchard View (local dashboard) config.
#
# Copy to dashboard/.env and edit. .env is gitignored.

# Where Orchard View itself listens.
ORCHARD_VIEW_HOST=127.0.0.1
ORCHARD_VIEW_PORT=5000

# Where the oracle is running. Default assumes localhost:8000 (same PC).
ORCHARD_VIEW_ORACLE_URL=http://127.0.0.1:8000

# Default oracle URL the dashboard will push to a freshly-provisioned Tree.
# Usually your dev PC's LAN IP + the oracle port. Leave the host as
# 0.0.0.0 in the oracle config and use the LAN IP here so the Tree can
# actually reach it over WiFi.
ORCHARD_VIEW_TREE_ORACLE_URL=http://192.168.1.10:8000/readings

# Serial timeout in seconds for Tree commands. 3s is comfortable for
# the Tree's line-by-line responses.
ORCHARD_VIEW_SERIAL_TIMEOUT=3.0
